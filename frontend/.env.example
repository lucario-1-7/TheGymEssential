# Google OAuth client IDs for Drive backup. Create them at
# https://console.cloud.google.com -> APIs & Services -> Credentials.
# Copy this file to .env (which is gitignored) and fill in the values.

# Web application client (used by the browser / PWA build).
VITE_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Android client (used by the native Capacitor build). Type "Android",
# package com.thegymessential.app, with your signing SHA-1 fingerprint.
VITE_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
